<mujoco model="prometheus_surgical_robot">
  <!--
    PROMETHEUS — Autonomous Dual-Arm Dexterous Surgical Robot
    FFAI Robothon Summer 2026
    
    Master scene: dual 7-DOF arms + 24-DOF dexterous hands + surgical workspace
    Total DOF: 62 actively controlled joints + free bodies
  -->

  <compiler autolimits="true" angle="radian"/>

  <option timestep="0.001" integrator="Euler" cone="elliptic" solver="CG"
          iterations="100" tolerance="1e-8" gravity="0 0 -9.81">
    <flag contact="enable" constraint="enable" sensor="enable"/>
  </option>

  <size nconmax="2000" njmax="4000"/>

  <!-- ═══════════════════ VISUAL SETTINGS ═══════════════════ -->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <map znear="0.001" zfar="50" force="0.05"/>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <!-- ═══════════════════ DEFAULTS ═══════════════════ -->
  <default>
    <!-- Arm defaults -->
    <default class="arm_joint">
      <joint type="hinge" damping="20.0" armature="1.0" frictionloss="1.0"/>
      <geom type="capsule" rgba="0.25 0.25 0.28 1" contype="0" conaffinity="0"/>
    </default>

    <!-- Hand defaults -->
    <default class="finger_joint">
      <joint type="hinge" damping="1.0" armature="0.1" frictionloss="0.1"/>
    </default>
    <default class="finger_geom">
      <geom type="capsule" rgba="0.85 0.75 0.65 1" contype="0" conaffinity="0"
            friction="1.5 0.005 0.001" solimp="0.95 0.99 0.001" solref="0.004 1"/>
    </default>
    <default class="fingertip_geom">
      <geom type="sphere" rgba="0.90 0.78 0.68 1" contype="0" conaffinity="0"
            friction="2.0 0.01 0.001" solimp="0.95 0.99 0.001" solref="0.004 1"/>
    </default>

    <!-- Surgical tool defaults -->
    <default class="needle_geom">
      <geom type="capsule" rgba="0.75 0.75 0.80 1" contype="2" conaffinity="3"
            friction="1.0 0.005 0.001" mass="0.005"/>
    </default>
    <default class="thread_geom">
      <geom type="capsule" rgba="0.1 0.3 0.8 1" contype="2" conaffinity="3"
            friction="0.8 0.005 0.001" mass="0.01"/>
    </default>

    <!-- Tissue defaults -->
    <default class="tissue_geom">
      <geom type="box" rgba="0.85 0.55 0.50 1" contype="4" conaffinity="7"
            friction="1.2 0.01 0.001" solimp="0.90 0.95 0.005" solref="0.01 1.5"/>
    </default>

    <!-- Actuator defaults -->
    <default class="arm_actuator">
      <position kp="500" kv="50" ctrlrange="-3.14 3.14" forcerange="-200 200"/>
    </default>
    <default class="finger_actuator">
      <position kp="10" kv="1" forcerange="-5 5"/>
    </default>
  </default>

  <!-- ═══════════════════ ASSETS ═══════════════════ -->
  <asset>
    <!-- Textures -->
    <texture name="grid_tex" type="2d" builtin="checker" rgb1="0.08 0.12 0.08"
             rgb2="0.10 0.14 0.10" width="512" height="512"/>
    <texture name="steel_tex" type="2d" builtin="flat" rgb1="0.6 0.62 0.65"
             width="64" height="64"/>
    <texture name="tissue_tex" type="2d" builtin="flat" rgb1="0.85 0.55 0.50"
             width="64" height="64"/>
    <texture name="table_tex" type="2d" builtin="flat" rgb1="0.15 0.30 0.15"
             width="64" height="64"/>
    <texture name="sky_tex" type="skybox" builtin="gradient"
             rgb1="0.05 0.08 0.15" rgb2="0.15 0.20 0.30" width="256" height="256"/>

    <!-- Materials -->
    <material name="floor_mat" texture="grid_tex" texrepeat="10 10"
              reflectance="0.15" specular="0.2" shininess="0.3"/>
    <material name="steel_mat" texture="steel_tex" specular="0.8" shininess="0.9"
              reflectance="0.3" rgba="0.65 0.67 0.70 1"/>
    <material name="table_mat" texture="table_tex" specular="0.1" shininess="0.3"
              rgba="0.15 0.35 0.15 1"/>
    <material name="tissue_mat" texture="tissue_tex" specular="0.1" shininess="0.1"
              rgba="0.88 0.55 0.50 1"/>
    <material name="skin_mat" specular="0.05" shininess="0.1"
              rgba="0.85 0.75 0.65 1"/>
    <material name="robot_mat" specular="0.6" shininess="0.7"
              rgba="0.25 0.25 0.28 1"/>
    <material name="needle_mat" specular="0.9" shininess="0.95"
              rgba="0.78 0.78 0.82 1" reflectance="0.4"/>
    <material name="thread_mat" specular="0.1" shininess="0.1"
              rgba="0.1 0.3 0.8 1"/>
    <material name="wound_mat" specular="0.05" shininess="0.1"
              rgba="0.7 0.2 0.2 1"/>
    <material name="base_mat" specular="0.4" shininess="0.5"
              rgba="0.2 0.2 0.22 1"/>
  </asset>

  <!-- ═══════════════════ WORLDBODY ═══════════════════ -->
  <worldbody>
    <!-- Lighting -->
    <light name="overhead_light" pos="0 0 2.5" dir="0 0 -1" diffuse="0.8 0.8 0.85"
           specular="0.5 0.5 0.5" ambient="0.15 0.15 0.18" castshadow="true"
           cutoff="60" directional="false"/>
    <light name="surgical_light_1" pos="0.3 0.3 1.8" dir="-0.2 -0.2 -1"
           diffuse="0.9 0.9 0.95" specular="0.7 0.7 0.7" castshadow="true"
           cutoff="45"/>
    <light name="surgical_light_2" pos="-0.3 -0.3 1.8" dir="0.2 0.2 -1"
           diffuse="0.7 0.7 0.75" specular="0.4 0.4 0.4" castshadow="true"
           cutoff="45"/>
    <light name="fill_light" pos="0 1.5 1.0" dir="0 -1 -0.3"
           diffuse="0.3 0.3 0.35" castshadow="false"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="5 5 0.01" material="floor_mat"
          contype="8" conaffinity="8"/>

    <!-- ═══════════════ CAMERAS ═══════════════ -->
    <camera name="overview" pos="0.8 -1.0 1.5" xyaxes="0.8 0.6 0 -0.3 0.4 0.86"
            fovy="50"/>
    <camera name="top_down" pos="0 0 2.0" xyaxes="1 0 0 0 1 0" fovy="40"/>
    <camera name="hands_close" pos="0.0 -0.4 1.15" xyaxes="1 0 0 0 0.3 0.95"
            fovy="35"/>
    <camera name="right_side" pos="0.8 0 1.1" xyaxes="0 1 0 -0.3 0 0.95"
            fovy="45"/>
    <camera name="left_side" pos="-0.8 0 1.1" xyaxes="0 -1 0 0.3 0 0.95"
            fovy="45"/>
    <camera name="detail" pos="0.05 -0.25 1.12" xyaxes="1 0 0 0 0.2 0.98"
            fovy="25"/>

    <!-- ═══════════════ OPERATING TABLE ═══════════════ -->
    <body name="table" pos="0 0 0.75">
      <geom name="table_top" type="box" size="0.5 0.35 0.025" material="table_mat"/>
      <geom name="table_leg_1" type="cylinder" fromto="-0.4 -0.28 -0.025 -0.4 -0.28 -0.75"
            size="0.03" material="steel_mat"/>
      <geom name="table_leg_2" type="cylinder" fromto="0.4 -0.28 -0.025 0.4 -0.28 -0.75"
            size="0.03" material="steel_mat"/>
      <geom name="table_leg_3" type="cylinder" fromto="-0.4 0.28 -0.025 -0.4 0.28 -0.75"
            size="0.03" material="steel_mat"/>
      <geom name="table_leg_4" type="cylinder" fromto="0.4 0.28 -0.025 0.4 0.28 -0.75"
            size="0.03" material="steel_mat"/>

      <!-- ═══════════ TISSUE PAD (Left side of wound) ═══════════ -->
      <body name="tissue_pad_left" pos="-0.05 0 0.025">
        <geom name="tissue_left_base" type="box" size="0.12 0.15 0.015" material="tissue_mat"/>
        <!-- Wound edge — slightly raised -->
        <geom name="wound_edge_left" type="box" pos="0.11 0 0.01" size="0.015 0.12 0.008"
              material="wound_mat"/>
        <!-- Surface detail bumps for realism -->
        <geom name="tissue_detail_l1" type="sphere" pos="-0.05 0.05 0.015" size="0.008"
              material="tissue_mat" contype="0" conaffinity="0"/>
        <geom name="tissue_detail_l2" type="sphere" pos="-0.03 -0.04 0.015" size="0.006"
              material="tissue_mat" contype="0" conaffinity="0"/>
        <geom name="tissue_detail_l3" type="sphere" pos="-0.08 0.02 0.015" size="0.007"
              material="tissue_mat" contype="0" conaffinity="0"/>

        <!-- Suture entry point markers -->
        <site name="entry_point_1" pos="0.10 0.06 0.015" size="0.003" rgba="0 1 0 0.8"/>
        <site name="entry_point_2" pos="0.10 0.02 0.015" size="0.003" rgba="0 1 0 0.8"/>
        <site name="entry_point_3" pos="0.10 -0.02 0.015" size="0.003" rgba="0 1 0 0.8"/>
        <site name="entry_point_4" pos="0.10 -0.06 0.015" size="0.003" rgba="0 1 0 0.8"/>
      </body>

      <!-- ═══════════ TISSUE PAD (Right side of wound) ═══════════ -->
      <body name="tissue_pad_right" pos="0.05 0 0.025">
        <geom name="tissue_right_base" type="box" size="0.12 0.15 0.015" material="tissue_mat"/>
        <!-- Wound edge -->
        <geom name="wound_edge_right" type="box" pos="-0.11 0 0.01" size="0.015 0.12 0.008"
              material="wound_mat"/>
        <!-- Surface detail bumps -->
        <geom name="tissue_detail_r1" type="sphere" pos="0.05 0.05 0.015" size="0.008"
              material="tissue_mat" contype="0" conaffinity="0"/>
        <geom name="tissue_detail_r2" type="sphere" pos="0.03 -0.04 0.015" size="0.006"
              material="tissue_mat" contype="0" conaffinity="0"/>

        <!-- Suture exit point markers -->
        <site name="exit_point_1" pos="-0.10 0.06 0.015" size="0.003" rgba="1 0.5 0 0.8"/>
        <site name="exit_point_2" pos="-0.10 0.02 0.015" size="0.003" rgba="1 0.5 0 0.8"/>
        <site name="exit_point_3" pos="-0.10 -0.02 0.015" size="0.003" rgba="1 0.5 0 0.8"/>
        <site name="exit_point_4" pos="-0.10 -0.06 0.015" size="0.003" rgba="1 0.5 0 0.8"/>
      </body>

      <!-- Wound gap visualization -->
      <geom name="wound_gap" type="box" pos="0 0 0.02" size="0.008 0.12 0.012"
            rgba="0.5 0.15 0.15 0.6" contype="0" conaffinity="0"/>

      <!-- Instrument tray -->
      <body name="instrument_tray" pos="0.35 0 0.025">
        <geom name="tray_base" type="box" size="0.08 0.12 0.005" material="steel_mat"/>
        <geom name="tray_rim_1" type="box" pos="0 -0.12 0.01" size="0.08 0.003 0.01"
              material="steel_mat"/>
        <geom name="tray_rim_2" type="box" pos="0 0.12 0.01" size="0.08 0.003 0.01"
              material="steel_mat"/>
        <geom name="tray_rim_3" type="box" pos="-0.08 0 0.01" size="0.003 0.12 0.01"
              material="steel_mat"/>
        <geom name="tray_rim_4" type="box" pos="0.08 0 0.01" size="0.003 0.12 0.01"
              material="steel_mat"/>
      </body>
    </body>

    <!-- ═══════════════════ ROBOT BASE ═══════════════════ -->
    <body name="robot_base" pos="0 -0.45 0.75">
      <geom name="base_plate" type="box" size="0.3 0.05 0.02" material="base_mat"/>
      <geom name="base_pillar" type="cylinder" fromto="0 0 -0.02 0 0 -0.75"
            size="0.05" material="base_mat"/>

      <!-- ═══════════════ RIGHT ARM (7-DOF) ═══════════════ -->
      <body name="right_shoulder_base" pos="0.12 0.03 0.03">
        <geom name="r_shoulder_housing" type="sphere" size="0.04" material="robot_mat"/>
        <joint name="r_shoulder_yaw" class="arm_joint" axis="0 0 1" range="-2.0 2.0"/>
        <joint name="r_shoulder_pitch" class="arm_joint" axis="0 1 0" range="-1.57 2.5"/>
        <joint name="r_shoulder_roll" class="arm_joint" axis="1 0 0" range="-1.57 1.57"/>
        <geom name="r_upper_arm" type="capsule" fromto="0 0 0 0.18 0 0"
              size="0.025" material="robot_mat"/>

        <body name="right_elbow" pos="0.18 0 0">
          <geom name="r_elbow_joint_geom" type="sphere" size="0.028" material="robot_mat"/>
          <joint name="r_elbow_flex" class="arm_joint" axis="0 1 0" range="0 2.5"/>
          <geom name="r_forearm" type="capsule" fromto="0 0 0 0.16 0 0"
                size="0.022" material="robot_mat"/>

          <body name="right_wrist" pos="0.16 0 0">
            <geom name="r_wrist_geom" type="sphere" size="0.022" material="robot_mat"/>
            <joint name="r_wrist_pronation" class="arm_joint" axis="1 0 0" range="-1.57 1.57" damping="5.0"/>
            <joint name="r_wrist_flex" class="arm_joint" axis="0 1 0" range="-1.0 1.0" damping="5.0"/>
            <joint name="r_wrist_dev" class="arm_joint" axis="0 0 1" range="-0.5 0.5" damping="5.0"/>

            <body name="r_palm" pos="0.03 0 0">
              <geom name="r_palm_geom" type="box" size="0.035 0.04 0.012" material="skin_mat"/>
              <site name="r_palm_touch" pos="0 0 0.012" size="0.02 0.03 0.001" type="box" rgba="0 0.8 0 0.3"/>
              <body name="r_thumb_cmc" pos="0.02 -0.035 0.005" euler="0 0.3 -0.8">
                <geom name="r_thumb_cmc_geom" class="finger_geom" fromto="0 0 0 0.025 0 0" size="0.009"/>
                <joint name="r_thumb_cmc_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.4"/>
                <joint name="r_thumb_cmc_abd" class="finger_joint" axis="0 0 1" range="-0.5 0.5"/>
                <body name="r_thumb_mcp" pos="0.025 0 0">
                  <geom name="r_thumb_mcp_geom" class="finger_geom" fromto="0 0 0 0.022 0 0" size="0.008"/>
                  <joint name="r_thumb_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.1 1.2"/>
                  <body name="r_thumb_ip" pos="0.022 0 0">
                    <geom name="r_thumb_ip_geom" class="finger_geom" fromto="0 0 0 0.018 0 0" size="0.007"/>
                    <joint name="r_thumb_ip_flex" class="finger_joint" axis="0 1 0" range="-0.1 1.0"/>
                    <body name="r_thumb_tip" pos="0.018 0 0">
                      <geom name="r_thumb_tip_geom" class="fingertip_geom" size="0.008"/>
                      <site name="r_thumb_touch" pos="0 0 0" size="0.008" rgba="0 0.8 0 0.3"/>
                    </body>
                  </body>
                </body>
              </body>
              <body name="r_index_mcp_base" pos="0.035 -0.022 0.008" euler="0 0 -0.1">
                <joint name="r_index_abd" class="finger_joint" axis="0 0 1" range="-0.3 0.3"/>
                <joint name="r_index_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.57"/>
                <geom name="r_index_prox" class="finger_geom" fromto="0 0 0 0.032 0 0" size="0.007"/>
                <body name="r_index_pip" pos="0.032 0 0">
                  <joint name="r_index_pip_flex" class="finger_joint" axis="0 1 0" range="0 1.8"/>
                  <geom name="r_index_mid" class="finger_geom" fromto="0 0 0 0.022 0 0" size="0.006"/>
                  <body name="r_index_dip" pos="0.022 0 0">
                    <joint name="r_index_dip_flex" class="finger_joint" axis="0 1 0" range="0 1.3"/>
                    <geom name="r_index_dist" class="finger_geom" fromto="0 0 0 0.018 0 0" size="0.0055"/>
                    <body name="r_index_tip" pos="0.018 0 0">
                      <geom name="r_index_tip_geom" class="fingertip_geom" size="0.006"/>
                      <site name="r_index_touch" pos="0 0 0" size="0.006" rgba="0 0.8 0 0.3"/>
                    </body>
                  </body>
                </body>
              </body>
              <body name="r_middle_mcp_base" pos="0.038 -0.005 0.008">
                <joint name="r_middle_abd" class="finger_joint" axis="0 0 1" range="-0.2 0.2"/>
                <joint name="r_middle_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.57"/>
                <geom name="r_middle_prox" class="finger_geom" fromto="0 0 0 0.035 0 0" size="0.007"/>
                <body name="r_middle_pip" pos="0.035 0 0">
                  <joint name="r_middle_pip_flex" class="finger_joint" axis="0 1 0" range="0 1.8"/>
                  <geom name="r_middle_mid" class="finger_geom" fromto="0 0 0 0.025 0 0" size="0.006"/>
                  <body name="r_middle_dip" pos="0.025 0 0">
                    <joint name="r_middle_dip_flex" class="finger_joint" axis="0 1 0" range="0 1.3"/>
                    <geom name="r_middle_dist" class="finger_geom" fromto="0 0 0 0.018 0 0" size="0.0055"/>
                    <body name="r_middle_tip" pos="0.018 0 0">
                      <geom name="r_middle_tip_geom" class="fingertip_geom" size="0.006"/>
                      <site name="r_middle_touch" pos="0 0 0" size="0.006" rgba="0 0.8 0 0.3"/>
                    </body>
                  </body>
                </body>
              </body>
              <body name="r_ring_mcp_base" pos="0.035 0.012 0.008" euler="0 0 0.1">
                <joint name="r_ring_abd" class="finger_joint" axis="0 0 1" range="-0.2 0.2"/>
                <joint name="r_ring_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.57"/>
                <geom name="r_ring_prox" class="finger_geom" fromto="0 0 0 0.030 0 0" size="0.0065"/>
                <body name="r_ring_pip" pos="0.030 0 0">
                  <joint name="r_ring_pip_flex" class="finger_joint" axis="0 1 0" range="0 1.8"/>
                  <geom name="r_ring_mid" class="finger_geom" fromto="0 0 0 0.022 0 0" size="0.006"/>
                  <body name="r_ring_dip" pos="0.022 0 0">
                    <joint name="r_ring_dip_flex" class="finger_joint" axis="0 1 0" range="0 1.3"/>
                    <geom name="r_ring_dist" class="finger_geom" fromto="0 0 0 0.016 0 0" size="0.0055"/>
                    <body name="r_ring_tip" pos="0.016 0 0">
                      <geom name="r_ring_tip_geom" class="fingertip_geom" size="0.006"/>
                      <site name="r_ring_touch" pos="0 0 0" size="0.006" rgba="0 0.8 0 0.3"/>
                    </body>
                  </body>
                </body>
              </body>
              <body name="r_little_mcp_base" pos="0.030 0.028 0.006" euler="0 0 0.2">
                <joint name="r_little_abd" class="finger_joint" axis="0 0 1" range="-0.3 0.3"/>
                <joint name="r_little_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.57"/>
                <geom name="r_little_prox" class="finger_geom" fromto="0 0 0 0.025 0 0" size="0.006"/>
                <body name="r_little_pip" pos="0.025 0 0">
                  <joint name="r_little_pip_flex" class="finger_joint" axis="0 1 0" range="0 1.8"/>
                  <geom name="r_little_mid" class="finger_geom" fromto="0 0 0 0.018 0 0" size="0.0055"/>
                  <body name="r_little_dip" pos="0.018 0 0">
                    <joint name="r_little_dip_flex" class="finger_joint" axis="0 1 0" range="0 1.3"/>
                    <geom name="r_little_dist" class="finger_geom" fromto="0 0 0 0.014 0 0" size="0.005"/>
                    <body name="r_little_tip" pos="0.014 0 0">
                      <geom name="r_little_tip_geom" class="fingertip_geom" size="0.005"/>
                      <site name="r_little_touch" pos="0 0 0" size="0.005" rgba="0 0.8 0 0.3"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- ═══════════════ LEFT ARM (7-DOF) — Mirror of Right ═══════════════ -->
      <body name="left_shoulder_base" pos="-0.12 0.03 0.03">
        <geom name="l_shoulder_housing" type="sphere" size="0.04" material="robot_mat"/>
        <joint name="l_shoulder_yaw" class="arm_joint" axis="0 0 1" range="-2.0 2.0"/>
        <joint name="l_shoulder_pitch" class="arm_joint" axis="0 1 0" range="-1.57 2.5"/>
        <joint name="l_shoulder_roll" class="arm_joint" axis="1 0 0" range="-1.57 1.57"/>
        <geom name="l_upper_arm" type="capsule" fromto="0 0 0 -0.18 0 0"
              size="0.025" material="robot_mat"/>

        <body name="left_elbow" pos="-0.18 0 0">
          <geom name="l_elbow_joint_geom" type="sphere" size="0.028" material="robot_mat"/>
          <joint name="l_elbow_flex" class="arm_joint" axis="0 1 0" range="0 2.5"/>
          <geom name="l_forearm" type="capsule" fromto="0 0 0 -0.16 0 0"
                size="0.022" material="robot_mat"/>

          <body name="left_wrist" pos="-0.16 0 0">
            <geom name="l_wrist_geom" type="sphere" size="0.022" material="robot_mat"/>
            <joint name="l_wrist_pronation" class="arm_joint" axis="1 0 0" range="-1.57 1.57" damping="5.0"/>
            <joint name="l_wrist_flex" class="arm_joint" axis="0 1 0" range="-1.0 1.0" damping="5.0"/>
            <joint name="l_wrist_dev" class="arm_joint" axis="0 0 1" range="-0.5 0.5" damping="5.0"/>

            <body name="l_palm" pos="-0.03 0 0">
              <geom name="l_palm_geom" type="box" size="0.035 0.04 0.012" material="skin_mat"/>
              <site name="l_palm_touch" pos="0 0 0.012" size="0.02 0.03 0.001" type="box" rgba="0 0.8 0 0.3"/>
              <body name="l_thumb_cmc" pos="-0.02 -0.035 0.005" euler="0 -0.3 0.8">
                <geom name="l_thumb_cmc_geom" class="finger_geom" fromto="0 0 0 -0.025 0 0" size="0.009"/>
                <joint name="l_thumb_cmc_flex" class="finger_joint" axis="0 1 0" range="-0.2 1.4"/>
                <joint name="l_thumb_cmc_abd" class="finger_joint" axis="0 0 1" range="-0.5 0.5"/>
                <body name="l_thumb_mcp" pos="-0.025 0 0">
                  <geom name="l_thumb_mcp_geom" class="finger_geom" fromto="0 0 0 -0.022 0 0" size="0.008"/>
                  <joint name="l_thumb_mcp_flex" class="finger_joint" axis="0 1 0" range="-0.1 1.2"/>
                  <body name="l_thumb_ip" pos="-0.022 0 0">
