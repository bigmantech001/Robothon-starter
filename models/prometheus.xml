  <!-- PIP-DIP coupling: DIP follows PIP at ~0.67 ratio (anatomically accurate) -->
  <tendon>
    <!-- Right hand PIP-DIP coupling -->
    <fixed name="r_index_coupling" limited="true" range="-0.5 2.5">
      <joint joint="r_index_pip_flex" coef="1"/>
